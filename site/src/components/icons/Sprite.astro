---
// Единый SVG-спрайт ЭРА. Инжектится в Base.astro сразу после <body>.
// Заменяет 21 копию <symbol> по одному комплекту на каждой странице templates/*.html.
---

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="chev-7" viewBox="0 0 100 100">
      <path d="M 0 0 L 100 0 L 100 100 L 80 100 L 80 20 L 0 20 Z" fill="currentColor"/>
    </symbol>
    <symbol id="chev-arrow" viewBox="0 0 14 10">
      <path d="M 0 0 H 14 V 3 H 3 V 10 H 0 Z" fill="currentColor"/>
    </symbol>
    <symbol id="chev-mark" viewBox="0 0 22 14">
      <path d="M 0 0 H 22 V 4 H 4 V 14 H 0 Z" fill="currentColor"/>
    </symbol>
  </defs>
</svg>
