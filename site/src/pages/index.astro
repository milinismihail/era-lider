---
import Base from '../layouts/Base.astro';
import Chev from '../components/icons/Chev.astro';

const title = 'ЭРА · Оценка для решений, где нельзя ошибиться';
const description = 'Российский стандарт диагностики руководителей и команд. В реестре российского ПО №28543. 20 лет экспертизы BITOBE.';

const schemaProduct = {
  name: 'Система оценки руководителей ЭРА',
  description:
    'Российская методология оценки руководителей и команд: HEXACO, 16 мотиваторов, 11 деструкторов. Реестр РПО № 28543, российская нормативная база на 5 127 профилей.',
};
---

<Base
  title={title}
  description={description}
  activeKey="home"
  schemaType="Product"
  schemaProduct={schemaProduct}
>

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content" data-reveal>
      <div class="hero-meta">
        <Chev kind="mark" class="mark" />
        <span>ЭРА · Система оценки руководителей</span>
        <span class="divider"></span>
        <span>В реестре РПО № 28543</span>
      </div>
      <h1 class="h-display">Оценка для решений,<br>где <span class="accent-line">нельзя&nbsp;ошибиться</span>.</h1>
      <p class="hero-sub">Российский стандарт диагностики руководителей и команд. За ЭРА — 20 лет экспертизы BITOBE по развитию первых лиц крупнейших компаний страны.</p>
      <div class="hero-actions">
        <a href="#cta" class="btn btn-primary">
          Запросить демо-презентацию
          <Chev kind="arrow" class="btn-arrow" width="14" height="10" />
        </a>
        <a href="#how" class="btn btn-secondary">Смотреть пример отчёта</a>
      </div>
      <div class="hero-trust">
        <div class="hero-trust-item">4 года апробации</div>
        <div class="hero-trust-item">10 000+ сессий</div>
        <div class="hero-trust-item">5 127 профилей в базе</div>
        <div class="hero-trust-item">20 лет BITOBE</div>
      </div>
    </div>
    <div class="hero-graphic" data-reveal>
      <svg class="chev-main" viewBox="0 0 100 100"><use href="#chev-7"/></svg>
      <svg class="chev-sub" viewBox="0 0 100 100"><use href="#chev-7"/></svg>
      <svg class="chev-tiny" viewBox="0 0 100 100"><use href="#chev-7"/></svg>
      <div class="label">Три модуля · Одна система</div>
    </div>
  </div>
</section>

<section class="trust">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-metric" data-reveal>
        <div class="num">4<span class="unit">года</span></div>
        <div class="label">апробации методологии на российских руководителях</div>
      </div>
      <div class="trust-metric" data-reveal>
        <div class="num">10&thinsp;000<span class="unit">+</span></div>
        <div class="label">сессий обратной связи с руководителями</div>
      </div>
      <div class="trust-metric" data-reveal>
        <div class="num">5&thinsp;127</div>
        <div class="label">валидированных профилей в нормативной базе</div>
      </div>
      <div class="trust-metric" data-reveal>
        <div class="num">7<span class="unit">из 10</span></div>
        <div class="label">ключевых отраслей российской экономики</div>
      </div>
    </div>
    <div class="logos-wrap" data-reveal>
      <div class="logos-label"><Chev kind="mark" class="mark" /><span>Работаем с лидерами рынка</span></div>
      <div class="logos-row">
        <div class="logo-placeholder">ГАЗПРОМ</div>
        <div class="logo-placeholder">ГАЗПРОМНЕФТЬ</div>
        <div class="logo-placeholder">ВТБ</div>
        <div class="logo-placeholder">ПРАВИТЕЛЬСТВО&nbsp;МОСКВЫ</div>
        <div class="logo-placeholder">ЛСР</div>
        <div class="logo-placeholder">АБЗ-1</div>
        <div class="logo-placeholder">КОРУС&nbsp;КОНСАЛТИНГ</div>
        <div class="logo-placeholder">ЭНЕРГОСБЫТ+</div>
      </div>
    </div>
  </div>
</section>

<section class="scenarios" id="scenarios">
  <div class="container">
    <div class="scenarios-header" data-reveal>
      <div>
        <div class="eyebrow"><Chev kind="mark" class="eyebrow-mark" />Сценарии применения</div>
        <h2 class="h-section">Шесть задач, где нельзя ошибиться.</h2>
      </div>
      <p class="lead">ЭРА — не тест ради теста. Каждый сценарий решает конкретную бизнес-задачу первого лица: от назначения преемника до диагностики команды перед трансформацией.</p>
    </div>
    <div class="scenarios-grid">
      <a href="/scenarios/csuite" class="scenario-card" data-reveal>
        <div class="scenario-num">01</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 20 4 L 34 12 V 28 L 20 36 L 6 28 V 12 Z"/><path d="M 14 20 L 18 24 L 26 14" stroke-width="2"/></svg>
        </div>
        <h3 class="scenario-title">Подбор на C-level</h3>
        <p class="scenario-desc">Назначить того, кто действительно справится. Объективно, без эффекта харизмы и «лояльности».</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
      <a href="/scenarios/successors" class="scenario-card" data-reveal>
        <div class="scenario-num">02</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 4 34 V 14 L 20 6 L 36 14 V 34"/><path d="M 12 34 V 22 H 28 V 34"/><rect x="18" y="26" width="4" height="8" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="scenario-title">Преемники и кадровый резерв</h3>
        <p class="scenario-desc">Увидеть всех HiPo, а не только громких. Собрать пул преемников на 3 года вперёд.</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
      <a href="/scenarios/team" class="scenario-card" data-reveal>
        <div class="scenario-num">03</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="12"/><path d="M 20 8 V 32 M 8 20 H 32"/><circle cx="27" cy="13" r="2.5" fill="currentColor" stroke="none"/><circle cx="13" cy="27" r="2.5" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="scenario-title">Диагностика команды</h3>
        <p class="scenario-desc">Понять, где зажимы и где ресурс. Увидеть команду как систему, а не как сумму анкет.</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
      <a href="/scenarios/mna" class="scenario-card" data-reveal>
        <div class="scenario-num">04</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 6 20 H 18 M 22 20 H 34"/><path d="M 12 14 L 18 20 L 12 26"/><path d="M 28 14 L 22 20 L 28 26"/><rect x="18" y="17" width="4" height="6" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="scenario-title">M&amp;A и реструктуризация</h3>
        <p class="scenario-desc">Решить, кто остаётся, а кто уходит. Собрать новую команду без политических потерь.</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
      <a href="/scenarios/burnout" class="scenario-card" data-reveal>
        <div class="scenario-num">05</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 12 30 C 12 24, 16 20, 20 20 S 28 24, 28 30"/><circle cx="20" cy="14" r="5"/><path d="M 18 8 L 20 4 L 22 8 Z" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="scenario-title">Выгорание и риск ухода</h3>
        <p class="scenario-desc">Распознать до, а не после заявления. Сохранить ключевых людей, пока не поздно.</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
      <a href="/scenarios/transformation" class="scenario-card" data-reveal>
        <div class="scenario-num">06</div>
        <div class="scenario-icon">
          <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M 6 32 L 16 18 L 24 26 L 34 10"/><path d="M 26 10 H 34 V 18"/><circle cx="16" cy="18" r="2.5" fill="currentColor" stroke="none"/><circle cx="24" cy="26" r="2.5" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3 class="scenario-title">Трансформация</h3>
        <p class="scenario-desc">Собрать команду под новые задачи. Понять, кто потянет следующий этап, а кто уже не сможет.</p>
        <span class="scenario-more">Подробнее <Chev kind="arrow" class="chev-arrow" /></span>
      </a>
    </div>
  </div>
</section>

<section class="how" id="how">
  <div class="container">
    <div class="how-header" data-reveal>
      <div class="eyebrow"><Chev kind="mark" class="eyebrow-mark" />Как работает ЭРА</div>
      <h2 class="h-section">Оценка — это старт, а не финальная точка.</h2>
    </div>
    <div class="how-timeline">
      <div class="step" data-reveal>
        <div class="step-num"><Chev kind="mark" class="chev" />01 / 05</div>
        <div class="step-title">Тестирование</div>
        <div class="step-meta">45–60 минут</div>
        <div class="step-desc">Три опросника: личность (HEXACO), мотивация (Ричи-Мартин, Рисс), стресс-поведение.</div>
      </div>
      <div class="step" data-reveal>
        <div class="step-num"><Chev kind="mark" class="chev" />02 / 05</div>
        <div class="step-title">Обратная связь с экспертом</div>
        <div class="step-meta">90 минут</div>
        <div class="step-desc">Разбор профиля с действующим экспертом ЭРА. Без ярлыков и категоризации.</div>
      </div>
      <div class="step" data-reveal>
        <div class="step-num"><Chev kind="mark" class="chev" />03 / 05</div>
        <div class="step-title">ИПР</div>
        <div class="step-meta">2 недели</div>
        <div class="step-desc">Индивидуальный план развития под конкретные бизнес-задачи руководителя.</div>
      </div>
      <div class="step" data-reveal>
        <div class="step-num"><Chev kind="mark" class="chev" />04 / 05</div>
        <div class="step-title">Проработка зон развития</div>
        <div class="step-meta">3–6 месяцев</div>
        <div class="step-desc">Коучинг, целевые программы, точечные решения. Не папка в архиве — работающий актив.</div>
      </div>
      <div class="step" data-reveal>
        <div class="step-num"><Chev kind="mark" class="chev" />05 / 05</div>
        <div class="step-title">Командный профиль</div>
        <div class="step-meta">По запросу</div>
        <div class="step-desc">Сборка команды как системы: где усиление, где слепые зоны, где потенциал конфликта.</div>
      </div>
    </div>
  </div>
</section>

<section class="q-block">
  <div class="container">
    <div class="q-header" data-reveal>
      <div>
        <div class="eyebrow"><Chev kind="mark" class="eyebrow-mark" />Методологический фундамент</div>
        <h2 class="h-section">Три опросника — три измерения руководителя.</h2>
      </div>
      <p class="lead">Не самооценка, а предикция поведения. Шестифакторная модель HEXACO, 16 мотиваторов Ричи-Мартин и Рисс, 11 стресс-деструкторов — сопоставлено с HPI/HDS/MVPI.</p>
    </div>
    <div class="q-grid">
      <div class="q-card mod-pers" data-reveal>
        <Chev kind="7" class="q-corner" />
        <div class="q-num">Опросник 01 · Личность</div>
        <h3 class="q-title">Личностные черты</h3>
        <div class="q-scale">6<span class="dim">/ факторов HEXACO</span></div>
        <div class="q-minigraph"><span style="height: 72%"></span><span style="height: 58%"></span><span style="height: 85%"></span><span style="height: 44%"></span><span style="height: 67%"></span><span style="height: 91%"></span></div>
        <p class="q-desc">Модель HEXACO добавляет к Big Five фактор Честности-Смирения — критичный в российской управленческой культуре.</p>
        <a href="/methodology#hexaco" class="q-link">Подробнее <Chev kind="arrow" class="chev" /></a>
      </div>
      <div class="q-card mod-mot" data-reveal>
        <Chev kind="7" class="q-corner" />
        <div class="q-num">Опросник 02 · Мотивация</div>
        <h3 class="q-title">Мотивационные драйверы</h3>
        <div class="q-scale">16<span class="dim">/ драйверов</span></div>
        <div class="q-minigraph"><span style="height: 40%"></span><span style="height: 75%"></span><span style="height: 30%"></span><span style="height: 88%"></span><span style="height: 55%"></span><span style="height: 65%"></span><span style="height: 92%"></span><span style="height: 48%"></span></div>
        <p class="q-desc">Ричи-Мартин и Рисс — самая детальная шкала мотивации на рынке. Глубже, чем MVPI Hogan.</p>
        <a href="/methodology#motivation" class="q-link">Подробнее <Chev kind="arrow" class="chev" /></a>
      </div>
      <div class="q-card mod-destr" data-reveal>
        <Chev kind="7" class="q-corner" />
        <div class="q-num">Опросник 03 · Деструкторы</div>
        <h3 class="q-title">Стресс-поведение</h3>
        <div class="q-scale">11<span class="dim">/ деструкторов</span></div>
        <div class="q-minigraph"><span style="height: 25%"></span><span style="height: 52%"></span><span style="height: 78%"></span><span style="height: 34%"></span><span style="height: 46%"></span><span style="height: 82%"></span><span style="height: 38%"></span></div>
        <p class="q-desc">Что случается с руководителем «под давлением». Паттерны, которые не видны в интервью, но ломают команды.</p>
        <a href="/methodology#destructors" class="q-link">Подробнее <Chev kind="arrow" class="chev" /></a>
      </div>
    </div>
  </div>
</section>

<section class="case" id="case">
  <div class="container case-inner">
    <div class="case-left" data-reveal>
      <div class="eyebrow on-dark"><Chev kind="mark" class="eyebrow-mark" style="color: var(--white)" />Флагманский кейс</div>
      <h2 class="h-section">Подбор преемника в производственный холдинг.</h2>
      <p class="case-left-lead">Крупный промышленный заказчик. Уход CEO через 14 месяцев. Четыре внутренних кандидата, внешний поиск под вопросом. ЭРА как инструмент объективного сравнения.</p>
      <div class="case-company">
        <div class="case-company-logo">ПХ</div>
        <div class="case-company-info">
          <div class="name">Производственный холдинг</div>
          <div class="industry">МЕТАЛЛУРГИЯ · 12 000 СОТРУДНИКОВ</div>
        </div>
      </div>
    </div>
    <div class="case-right">
      <div class="case-step" data-reveal>
        <div class="case-step-label">01 · Контекст</div>
        <h3>CEO объявил об уходе. Четыре внутренних кандидата — и ни одного очевидного.</h3>
        <p>Ключевой акционер дал 14 месяцев на transition. Внутри — четыре директора с сопоставимыми track record. Выбор по интуиции — риск на уровне всего холдинга. Нужна объективная матрица сравнения, включая зоны, которые не видны в квартальных отчётах.</p>
      </div>
      <div class="case-step" data-reveal>
        <div class="case-step-label">02 · Что сделали</div>
        <h3>Оценка ЭРА для всех четверых + executive assessment от экспертов BITOBE.</h3>
        <p>Индивидуальные профили HEXACO + мотивация + стресс-паттерны. Executive interview с каждым. Сведение в матрицу сравнения по восьми компетенциям CEO, включая устойчивость к давлению, готовность к непопулярным решениям, мотивационный профиль под масштаб задачи.</p>
      </div>
      <div class="case-step" data-reveal>
        <div class="case-step-label">03 · Решение</div>
        <h3>Преемник выбран по данным, не по «ощущению». Три оставшихся — в целевой программе развития.</h3>
        <p>Победивший кандидат — не тот, кого бы выбрали интуитивно. Стресс-профиль и мотивационная карта однозначно указали на устойчивость и готовность к масштабу. Три других — остались в команде с ИПР под конкретные зоны роста и с понятной перспективой.</p>
      </div>
      <div class="case-results" data-reveal>
        <div class="case-results-title"><Chev kind="mark" class="chev" />Результат через 24 месяца</div>
        <div class="case-results-grid">
          <div class="case-result"><div class="num">0</div><div class="desc">Ключевых уходов в C-level за период transition</div></div>
          <div class="case-result"><div class="num">+18%</div><div class="desc">EBITDA холдинга за два года после назначения</div></div>
          <div class="case-result"><div class="num">94%</div><div class="desc">NPS команды по оценке нового CEO (внутренний опрос)</div></div>
          <div class="case-result"><div class="num">×3</div><div class="desc">Сокращение срока стратегических решений</div></div>
        </div>
        <a href="/cases" class="btn btn-primary">Все кейсы <Chev kind="arrow" class="btn-arrow" width="14" height="10" /></a>
      </div>
    </div>
  </div>
</section>

<section class="more-cases">
  <div class="container">
    <div class="more-cases-header" data-reveal>
      <div>
        <div class="eyebrow"><Chev kind="mark" class="eyebrow-mark" />Ещё кейсы</div>
        <h2 class="h-section">Развитие руководителя и&nbsp;командные трансформации.</h2>
      </div>
      <p class="lead">Два сценария, в которых ЭРА показала себя в&nbsp;инфраструктуре и крупном b2b. Развитие конкретного руководителя и диагностика команды снабжения для перераспределения ответственности.</p>
    </div>

    <div class="cases-row">

      <a href="/cases/abz-1" class="case-card" data-reveal>
        <div class="case-card-header">
          <div class="case-card-logo">АБЗ<br>1</div>
          <div class="case-card-meta">
            <div class="name">Группа АБЗ-1</div>
            <div class="industry">Дорожное строительство · СПб</div>
          </div>
        </div>
        <div class="case-card-scenario"><Chev kind="mark" class="chev" />Развитие руководителя</div>
        <h3 class="case-card-title">Объективная картина профессионального поведения для зон роста.</h3>
        <p class="case-card-quote">
          Удалось составить объективную картину профессионального поведения руководителя — подчеркнули основные сильные стороны и зоны развития. Результаты легли в основу индивидуального плана развития.
          <span class="case-card-quote-source">— из благодарственного письма АБЗ-Дорстрой, 2025</span>
        </p>
        <div class="case-card-results">
          <div class="case-card-result"><div class="num">1</div><div class="desc">Руководитель в фокусной оценке</div></div>
          <div class="case-card-result"><div class="num">3</div><div class="desc">Опросника + сессия обратной связи</div></div>
          <div class="case-card-result"><div class="num">ИПР</div><div class="desc">Индивидуальный план под бизнес-задачи</div></div>
        </div>
        <span class="case-card-link">Подробнее о кейсе <Chev kind="arrow" class="chev" /></span>
      </a>

      <a href="/cases/gpn-snabzhenie" class="case-card" data-reveal>
        <div class="case-card-header">
          <div class="case-card-logo">ГПН<br>Снаб</div>
          <div class="case-card-meta">
            <div class="name">Газпромнефть Снабжение</div>
            <div class="industry">b2b закупки · нефтегаз</div>
          </div>
        </div>
        <div class="case-card-scenario"><Chev kind="mark" class="chev" />Диагностика команды</div>
        <h3 class="case-card-title">Командные отчёты как основа для перераспределения ответственности.</h3>
        <p class="case-card-quote">
          Итоговые командные отчёты дали детальную характеристику каждой из команд. Выявлен потенциал и зоны роста, сформированы рекомендации по работе с каждым сотрудником и кросс-функциональному взаимодействию.
