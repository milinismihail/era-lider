---
import Base from '../layouts/Base.astro';
import Chev from '../components/icons/Chev.astro';
import TocSidebar from '../components/methodology/TocSidebar.astro';
import SectionHead from '../components/methodology/SectionHead.astro';
import {
  hexacoFactors,
  motivators,
  destructors,
  correlationRows,
  alphaRows,
  normBreakdown,
  complianceItems,
  methodologyPublications,
} from '../data/methodology.ts';

const title = 'Методология ЭРА · HEXACO, валидность, надёжность';
const description =
  'Методологическое обоснование системы ЭРА: модель HEXACO, валидность, надёжность, корреляции с HPI/HDS/MVPI, нормативная база на российской выборке.';

const schemaProduct = {
  name: 'Методология ЭРА (HEXACO-PI-R)',
  description:
    'Шестифакторная модель HEXACO, 16 мотиваторов, 11 деструкторов. Валидность r до 0.83, α-Кронбаха 0.72–0.91, нормативная база 5 127 профилей. Соответствие ГОСТ Р 71009-2023, APA, ITC.',
};

const breadcrumbs = [
  { name: 'Главная', url: 'https://era-lider.ru/' },
  { name: 'Методология', url: 'https://era-lider.ru/methodology' },
];
---

<Base
  title={title}
  description={description}
  activeKey="methodology"
  schemaType="Product"
  schemaProduct={schemaProduct}
  breadcrumbs={breadcrumbs}
>

<section class="meth-hero">
  <div class="container">
    <div class="hero-breadcrumbs">
      <a href="/">Главная</a>
      <span class="sep">/</span>
      <span class="current">Методология</span>
    </div>
    <div class="meth-hero-grid">
      <div data-reveal>
        <div class="eyebrow" style="margin-bottom: 28px;">
          <Chev kind="mark" class="eyebrow-mark" />
          Методологический раздел
        </div>
        <h1 class="h-hero">
          За каждым профилем —<br>
          20 лет психометрии<br>
          и нормативная база <span class="accent-line">5&nbsp;000+</span>.
        </h1>
        <p class="meth-hero-lead">
          Модель HEXACO, мотивационные шкалы Ричи-Мартин и Рисс, 11 деструкторов поведения под стрессом. Валидность подтверждена корреляциями с HPI, HDS, MVPI. Надёжность — коэффициентами α-Кронбаха от 0.72 до 0.91.
        </p>
      </div>
      <div class="meth-hero-meta" data-reveal>
        <div class="meth-hero-meta-item">
          <div class="label">Модель</div>
          <div class="value">HEXACO-PI-R</div>
        </div>
        <div class="meth-hero-meta-item">
          <div class="label">Шкал всего</div>
          <div class="value">33 <span class="dim">+ 2</span></div>
        </div>
        <div class="meth-hero-meta-item">
          <div class="label">Нормативная выборка</div>
          <div class="value">5&nbsp;127 <span class="dim">профилей</span></div>
        </div>
        <div class="meth-hero-meta-item">
          <div class="label">Средний α</div>
          <div class="value">0.83</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="main">
  <div class="container main-grid">

    <TocSidebar />

    <div class="content">

      <section id="philosophy" data-reveal>
        <SectionHead num="01" kicker="Исходная позиция">
          <h2 class="h-section">Мы измеряем <span class="accent-line">репутацию</span>, а не&nbsp;самооценку.</h2>
        </SectionHead>
        <p class="lead">
          Принципиальная разница между ассессмент-инструментами лежит не в технологии тестирования, а в том, что именно измеряется. ЭРА построена на концепции identity vs. reputation Хогана, но с важным уточнением: для управленческих решений значение имеет не то, как человек видит себя, а то, как его поведение предсказуемо считывается другими.
        </p>
        <p>
          Это значит, что опросники ЭРА ориентированы не на фиксацию внутренних переживаний, а на предикцию наблюдаемого поведения в рабочем контексте — в том числе под давлением, в условиях многозадачности, при конфликте интересов. Ответы калибруются через нормативную базу российских руководителей, а не переносятся с зарубежных выборок.
        </p>
        <div class="callout">
          <div class="q-title">«Оценка руководителя — это не диагностика личности. Это карта предсказуемых реакций. Что он сделает, когда будет тяжело, а не что о себе думает, когда всё хорошо.»</div>
          <div class="q-src">Н. Боровикова · руководитель методологии ЭРА</div>
        </div>
      </section>

      <section id="hexaco" data-reveal>
        <SectionHead num="02" kicker="Опросник 01 · Личность" kickerMod="pers">
          <h2 class="h-section">HEXACO — <span class="accent-line mod-pers">шесть факторов</span>, не&nbsp;пять.</h2>
        </SectionHead>
        <p class="lead">
          ЭРА использует шестифакторную модель HEXACO (Ashton &amp; Lee, 2001–2007), а не классическую Big Five. Ключевое отличие — дополнительный фактор <strong>Честности-Смирения (H)</strong>, критично значимый в российской управленческой культуре.
        </p>
        <p>
          Исследования на российских выборках (МГУ, НИУ ВШЭ, 2015–2022) показывают, что фактор H обладает уникальной предиктивной валидностью в отношении контрпродуктивного поведения на работе, коррупционных рисков и этичности решений — то, что Big Five не измеряет напрямую.
        </p>

        <div class="factors">
          {hexacoFactors.map((f) => (
            <div class="factor">
              <div class="factor-code">{f.code}</div>
              <div class="factor-body">
                <div class="name">{f.name} <span class="en">{f.en}</span></div>
                <div class="desc">{f.desc}</div>
              </div>
              <div class="factor-bar">
                <div class="track"><div class="fill" style={`width:${f.width}%`}></div></div>
                <div class="val">{f.alpha}</div>
              </div>
            </div>
          ))}
        </div>

        <h3 class="h-sub" style="margin-top:40px; margin-bottom:20px;">HEXACO vs Big Five: почему шестой фактор важен</h3>
        <div class="table-wrap">
          <table class="comp-table">
            <thead>
              <tr>
                <th>Что измеряет</th>
                <th>HEXACO (ЭРА)</th>
                <th>Big Five (классические тесты)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="col-head">Этичность поведения</td><td class="cell-era">Отдельный фактор <span class="accent">H</span></td><td class="cell-b5">Рассеяно по шкалам A и C</td></tr>
              <tr><td class="col-head">Предикция контрпродуктивного поведения</td><td class="cell-era">R² ≈ 0.31</td><td class="cell-b5">R² ≈ 0.18</td></tr>
              <tr><td class="col-head">Манипулятивность / макиавеллизм</td><td class="cell-era">Низкий <span class="accent">H</span></td><td class="cell-b5">Отдельно не измеряется</td></tr>
              <tr><td class="col-head">Коррупционные риски</td><td class="cell-era">Прямая связь с <span class="accent">H</span></td><td class="cell-b5">Только косвенно</td></tr>
              <tr><td class="col-head">Совместимость с русскоязычной нормой</td><td class="cell-era">Адаптирована МГУ, 2015–2022</td><td class="cell-b5">Преимущественно западные нормы</td></tr>
            </tbody>
          </table>
        </div>
        <p class="table-caption">Мета-анализ Ashton, Lee &amp; de Vries (2014) показывает, что HEXACO с фактором H объясняет на <strong>13 процентных пунктов</strong> больше дисперсии в предикции этичного поведения по сравнению с Big Five. На российских выборках этот эффект ещё выраженнее.</p>
      </section>

      <section id="motivation" data-reveal>
        <SectionHead num="03" kicker="Опросник 02 · Мотивация" kickerMod="mot">
          <h2 class="h-section">16 мотиваторов: <span class="accent-line mod-mot">что включает</span> руководителя.</h2>
        </SectionHead>
        <p class="lead">
          Мотивационный профиль ЭРА собран на пересечении двух зрелых моделей: Ричи-Мартин (12 факторов) и Рисс (16 базовых потребностей). Результирующая шкала — 16 драйверов, отобранных по принципу максимальной независимости и валидности для управленческого контекста.
        </p>
        <p>
          В отличие от MVPI Hogan (10 шкал), шкала ЭРА позволяет различать тонкие мотивационные сочетания: например, «власть ради влияния» vs «власть ради автономии» — то, что критично при подборе на C-level позиции.
        </p>

        <div class="mot-grid">
          {motivators.map((m) => (
            <div class="mot-item">
              <span class="code">{m.code}</span>
              <div class="text">{m.name}<span class="dim">{m.dim}</span></div>
            </div>
          ))}
        </div>
      </section>

      <section id="destructors" data-reveal>
        <SectionHead num="04" kicker="Опросник 03 · Деструкторы" kickerMod="destr">
          <h2 class="h-section">11 деструкторов: что происходит <span class="accent-line mod-destr">под давлением</span>.</h2>
        </SectionHead>
        <p class="lead">
          Стресс-поведение — это не патология, а нормальная реакция на перегрузку, которая у каждого проявляется в своём паттерне. ЭРА диагностирует 11 типовых деструкторов, производных от модели HDS Hogan с адаптацией под российскую управленческую реальность.
        </p>
        <p>
          Эти шкалы не ставят диагноз, а прогнозируют: в какой форме руководитель будет «ломаться», когда ресурс стрессоустойчивости исчерпан. Для M&amp;A, реструктуризаций, кризисного управления — критичная информация, которой нет в интервью.
        </p>

        <div class="destr-list">
          {destructors.map((d) => (
            <div class="destr-item">
              <div class="num">{d.num}</div>
              <div class="name">{d.name}</div>
              <div class="desc">{d.desc}</div>
            </div>
          ))}
        </div>

        <p class="muted" style="font-size:14px;">Деструкторы D.01–D.11 соотнесены со шкалами HDS Hogan и проверены на российской выборке 2 840 руководителей. Методологическое описание — в <a href="#publications" class="inline-link">разделе 10</a>.</p>
      </section>

      <section id="validity" data-reveal>
        <SectionHead num="05" kicker="Доказательная база">
          <h2 class="h-section">Валидность: <span class="accent-line">корреляции</span> с HPI, HDS, MVPI.</h2>
        </SectionHead>
        <p class="lead">
          Конкурентная валидность ЭРА подтверждена прямыми корреляциями ключевых шкал с инструментами Hogan (HPI, HDS, MVPI) на выборке 1 247 руководителей, прошедших оба инструмента в 2022–2024 годах.
        </p>
        <p>
          Высокие корреляции (r &gt; 0.70) зафиксированы для шкал, измеряющих близкие конструкты; средние (0.50–0.70) — для шкал с частичным перекрытием; низкие (&lt; 0.40) — для шкал с принципиально разной операционализацией. Полная матрица публикуется в методическом отчёте ЭРА.
        </p>

        <div class="corr-wrap">
          <table class="corr-table">
            <thead>
              <tr>
                <th style="text-align:left;">Шкала ЭРА</th>
                <th>HPI (Hogan)</th>
                <th>HDS (Hogan)</th>
                <th>MVPI (Hogan)</th>
                <th>Big Five NEO</th>
              </tr>
            </thead>
            <tbody>
              {correlationRows.map((row) => (
                <tr>
                  <th>{row.scale}</th>
                  {row.cells.map((c) => (
                    <td class="cell" data-level={c.level}>
                      <span class="bg"></span><span class="val">{c.val}</span>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="table-caption"><strong>N&nbsp;=&nbsp;1&nbsp;247.</strong> Исследование 2022–2024, BITOBE совместно с Assessment Systems. Значения r Пирсона. Знак «−» означает обратную корреляцию (например, высокая Честность-Смирение связана с низкими баллами по HDS-шкале лицемерия).</p>

        <h3 class="h-sub" style="margin-top:40px; margin-bottom:16px;">Прогностическая валидность</h3>
        <p>
          Отдельное исследование на выборке 312 руководителей с двухлетним follow-up (2022–2024) подтвердило, что комбинация шкал <strong>Добросовестность + Стресс-устойчивость + Мотивация Достижения</strong> предсказывает результативность на позиции уровня «руководитель направления» с показателем R² = 0.34 — сопоставимо с лучшими западными инструментами.
        </p>
      </section>

      <section id="reliability" data-reveal>
        <SectionHead num="06" kicker="Психометрика">
          <h2 class="h-section">Надёжность: <span class="accent-line">α-Кронбаха</span> от 0.72 до 0.91.</h2>
        </SectionHead>
        <p class="lead">
          Внутренняя согласованность шкал ЭРА оценивалась через α-Кронбаха на нормативной выборке 5 127 профилей. Все основные шкалы превышают общепринятый порог 0.70, большинство — выше 0.80 (уровень, признанный достаточным для индивидуальной оценки).
        </p>

        <div class="alpha-list">
          <div class="alpha-row alpha-head">
            <div>Шкала</div><div>Пунктов</div><div>α</div><div></div>
          </div>
          {alphaRows.map((row) => (
            <div class="alpha-row">
              <div class="scale">{row.scale}</div>
              <div class="items">{row.items}</div>
              <div class="alpha-val">{row.alpha}</div>
              <div class="alpha-bar"><div class="fill" style={`width:${row.width}%`}></div></div>
            </div>
          ))}
        </div>

        <p class="table-caption"><strong>Средний α по всем шкалам = 0.83.</strong> Ретестовая надёжность (N=184, интервал 8 недель) составляет r = 0.81 для основных шкал HEXACO — показатель, сопоставимый с международными стандартами психометрического качества (APA, 2014).</p>
      </section>

      <section id="lie" data-reveal>
        <SectionHead num="07" kicker="Контроль искажений">
          <h2 class="h-section">Шкала <span class="accent-line">социальной желательности</span>.</h2>
        </SectionHead>
        <p class="lead">
          В ассессмент-ситуации, где результат влияет на карьерное решение, часть респондентов склонна давать «приукрашенные» ответы. ЭРА включает две встроенные шкалы контроля: шкалу социальной желательности (SD, 16 пунктов) и индекс невнимательности (IC, 4 зеркальных пункта).
        </p>
        <p>
          Профили с SD &gt; 85-го перцентиля автоматически помечаются как требующие интерпретационной осторожности. Эксперт ЭРА имеет протокол работы с такими случаями — от повторного интервью до корректировки весов при сводной оценке.
        </p>
        <div class="callout">
          <div class="q-title">«Лжи в психометрии не существует — есть только контекст, в котором человек хочет выглядеть лучше. Задача шкалы SD — не поймать обманщика, а подсказать интерпретатору, где стоит копнуть глубже.»</div>
          <div class="q-src">Е. Белоуско · ведущий психометрист ЭРА</div>
        </div>
      </section>

      <section id="normative" data-reveal>
        <SectionHead num="08" kicker="База норм">
          <h2 class="h-section">Нормативная выборка — <span class="accent-line">российская</span>.</h2>
        </SectionHead>
        <p class="lead">
          Все результаты ЭРА нормируются на российской выборке руководителей, собранной в 2020–2025 годах. Это отличает ЭРА от западных инструментов, которые либо используют глобальные нормы, либо адаптируют их с погрешностью на языковые различия.
        </p>

        <div class="norm-wrap">
          <div class="norm-grid">
            <div class="norm-item"><div class="num">5&nbsp;127</div><div class="label">Профилей в нормативной базе</div></div>
            <div class="norm-item"><div class="num">2022–25</div><div class="label">Годы сбора основной выборки</div></div>
            <div class="norm-item"><div class="num">41</div><div class="label">Средний возраст в выборке</div></div>
            <div class="norm-item"><div class="num">43%</div><div class="label">Доля женщин в выборке</div></div>
          </div>

          <div class="norm-breakdown">
            <div class="label">Распределение по отраслям</div>
            <ul>
              {normBreakdown.map((n) => (
                <li>{n.name} <span>{n.pct}</span></li>
              ))}
            </ul>
          </div>
        </div>

        <p>Раздельные нормы доступны по: (а) уровню позиции — CEO / C-level / руководитель направления / линейный руководитель; (б) функциональной области — производство / продажи / финансы / HR / ИТ; (в) отрасли — для 8 ведущих отраслей. Все нормы обновляются ежегодно.</p>
      </section>

      <section id="compliance" data-reveal>
        <SectionHead num="09" kicker="Соответствие стандартам">
          <h2 class="h-section">Регуляторика и <span class="accent-line">безопасность данных</span>.</h2>
        </SectionHead>
        <p class="lead">
          ЭРА соответствует требованиям российской регуляторной среды и международным стандартам психометрического качества. Все подтверждающие документы доступны для службы безопасности и юридических служб клиента.
        </p>

        <div class="compl-list">
          {complianceItems.map((c) => (
            <div class="compl-item">
              <div class="label">{c.label}</div>
              <div class="title">{c.title}</div>
              <div class="desc">{c.desc}</div>
              <a href={c.link.href}>{c.link.label} <Chev kind="arrow" class="chev" /></a>
            </div>
          ))}
        </div>
      </section>

      <section id="publications" data-reveal>
        <SectionHead num="10" kicker="Научная база">
          <h2 class="h-section">Публикации и <span class="accent-line">исследования</span>.</h2>
        </SectionHead>
        <p class="lead">
          Открытые материалы по методологии ЭРА: научные публикации команды, отраслевые бенчмарки, тематические white papers, короткие разборы действующих экспертов из Telegram-канала <a href="https://t.me/era_lider" target="_blank" rel="noopener" class="inline-link">@era_lider</a>. Все документы — в публичном доступе.
        </p>

        <ul class="pub-list">
          {methodologyPublications.map((p) => (
            <li>
              <a href={p.href} class="pub-row">
                <div class="year">{p.year}</div>
                <div>
                  <div class="title">{p.title}</div>
                  <div class="meta">{p.meta}</div>
                </div>
                <div class="arrow"><Chev kind="arrow" /></div>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </div>
</section>

<section class="cta-block" id="cta">
  <div class="container cta-grid">
    <div data-reveal>
      <div class="eyebrow on-dark" style="margin-bottom: 24px;">
        <Chev kind="mark" class="eyebrow-mark" style="color: var(--white)" />
        Для HR-методолога
      </div>
      <h2 class="h-section">Методический отчёт ЭРА — <span class="accent-line" style="color:var(--white);">86 страниц</span>.</h2>
      <p class="lead">
        Раздельные нормы, полные таблицы валидности, протокол интерпретации, кейсы применения. Для HR-методологов, психометристов и юридической службы клиента.
      </p>
    </div>
    <div class="cta-actions" data-reveal>
      <a href="/contact" class="btn btn-primary">Запросить методический отчёт <Chev kind="arrow" class="btn-arrow" width="14" height="10" /></a>
      <a href="/contact" class="btn btn-secondary-inverse">Разговор с экспертом ЭРА <Chev kind="arrow" class="btn-arrow" width="14" height="10" /></a>
    </div>
  </div>
</section>

<style is:global>
